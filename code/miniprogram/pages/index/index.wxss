.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  gap: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.refresh-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  transition: all 0.2s;
  flex-shrink: 0;
  cursor: pointer;
}
.refresh-box:active {
  transform: scale(0.95);
  background: #f0f0f0;
}
.refresh-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}
.refresh-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 20rpx;
  height: 70rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 100%;
}

.search-btn {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: bold;
  margin-left: 10rpx;
}

.login-btn {
  font-size: 24rpx;
  color: #666;
  background: #eee;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.pay-test-btn {
  font-size: 24rpx;
  color: #fff;
  background: #ff9800;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}


/* 登录弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  position: relative;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(50rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
}

.form-group {
  margin-bottom: 30rpx;
  position: relative;
}

.modal-input {
  width: 100%;
  height: 90rpx;
  background: #f5f5f5;
  border-radius: 15rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  cursor: pointer;
  z-index: 10;
  height: 90rpx;
}

.modal-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  margin-top: 40rpx;
}

.primary-btn {
  width: 100%;
  background: #4CAF50;
  color: #fff;
  font-size: 30rpx;
  border-radius: 45rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.register-link {
  font-size: 26rpx;
  color: #666;
}

.register-link .highlight {
  color: #4CAF50;
  font-weight: bold;
}

.quick-categories {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.category-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
}

.category-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
  width: 140rpx;
  margin-right: 20rpx;
}

.cat-item.cat-active .cat-name {
  color: #4CAF50;
  font-weight: bold;
}

.cat-item.cat-active .cat-icon-box {
  border: 2rpx solid #4CAF50;
  background: #F1F8F1;
}

.cat-icon-box {
  width: 90rpx;
  height: 90rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  border: 2rpx solid transparent;
}

.cat-icon-img {
  width: 60rpx;
  height: 60rpx;
}

.cat-name {
  font-size: 24rpx;
  color: #666;
}

.offer-section {
  margin: 20rpx 0;
}

.section-header-inline {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 20rpx;
  align-items: center;
}

.section-header-inline .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-header-inline .more {
  font-size: 24rpx;
  color: #999;
}

.offer-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.offer-item {
  display: inline-block;
  width: 280rpx;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
  padding: 0;
}

.offer-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: #FF5000;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-bottom-right-radius: 12rpx;
  z-index: 2;
}

.offer-img {
  width: 100%;
  height: 200rpx;
  background: #eee;
}

.offer-info {
  padding: 15rpx;
}

.offer-name {
  font-size: 24rpx;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 10rpx;
}

.offer-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.offer-price {
  color: #E4393C;
  font-size: 32rpx;
  font-weight: bold;
}

.offer-original {
  color: #999;
  text-decoration: line-through;
  font-size: 22rpx;
}

.promo-banner {
  margin: 20rpx;
  background: linear-gradient(to right, #FF5000, #FF8A00);
  color: white;
  padding: 40rpx;
  text-align: center;
}

.promo-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.promo-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.section-header {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  align-items: baseline;
}

.section-header .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-header .more {
  font-size: 24rpx;
  color: #999;
}

.product-list {
  padding: 0 20rpx 120rpx;
}

.product-item {
  display: flex;
  padding: 20rpx;
  position: relative;
}

.product-item.sold-out {
  background-color: #f9f9f9;
  opacity: 0.7;
}

.product-img-box {
  width: 180rpx;
  height: 180rpx;
  margin-right: 20rpx;
  position: relative;
}

.sold-out-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-bottom-left-radius: 12rpx;
  z-index: 10;
}

.product-img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #eee;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  line-height: 40rpx;
  display: block;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.current-price {
  color: #E4393C;
  font-size: 36rpx;
  font-weight: bold;
}

.unit {
  font-size: 22rpx;
  color: #999;
}

.tag-special {
  background: #E4393C;
  color: white;
  font-size: 20rpx;
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
}

.original-price {
  color: #999;
  text-decoration: line-through;
  font-size: 24rpx;
}

.cart-icon-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 30rpx;
}
