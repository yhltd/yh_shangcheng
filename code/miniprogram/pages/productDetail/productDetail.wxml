<view class="container">
  <view class="product-header card">
    <image src="{{img}}" mode="aspectFill" class="placeholder-img"></image>
    <view class="info">
      <text class="name">{{name}}</text>
      <view class="price-row">
        <text class="price">￥{{price}}</text>
        <text class="original-price" wx:if="{{originalPrice !== price}}">￥{{originalPrice}}</text>
      </view>
      <view class="category-tag">
        {{category}} {{subCategory ? '/ ' + subCategory : ''}}
      </view>
      <view class="shop-tag">商家：{{dianpu}}</view>
      <view class="stock-warning" wx:if="{{shuliang > 0 && shuliang < 10}}">
        仅剩 {{shuliang}} 件
      </view>
    </view>
  </view>

  <view class="detail-section card">
    <view class="section-title">商品详情</view>
    <text class="detail-text">{{detail}}</text>
  </view>

  <view class="action-bar">
    <view class="btn-cart" bindtap="handleAddToCart">加入购物车</view>
    <view class="quantity-selector" wx:if="{{shuliang > 0}}">
      <view class="qty-btn minus" bindtap="decreaseQty">−</view>
      <text class="qty-value">{{quantity}}</text>
      <view class="qty-btn plus" bindtap="increaseQty">+</view>
    </view>
    <view class="btn-buy bg-primary-green" style="{{shuliang <= 0 ? 'background: #ccc; pointer-events: none;' : ''}}" bindtap="handleBuy">
      {{shuliang <= 0 ? '已售罄' : '立即购买'}}
    </view>
  </view>
</view>
