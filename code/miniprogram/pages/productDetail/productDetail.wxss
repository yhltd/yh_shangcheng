.container {
  background: #f8f9fa;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.product-header {
  background: #fff;
  padding: 30rpx;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.placeholder-img {
  width: 100%;
  height: 600rpx;
  background: #eee;
  border-radius: 20rpx;
  display: block;
}

.info {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price {
  font-size: 48rpx;
  color: #E4393C;
  font-weight: bold;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.category-tag {
  font-size: 24rpx;
  color: #888;
  background: #f0f0f0;
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  width: fit-content;
}

.shop-tag {
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.shop-tag::before {
  content: '🏪';
  margin-right: 8rpx;
}

.stock-warning {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: bold;
  background: #fff1f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ffa39e;
  width: fit-content;
  animation: blink 2s infinite;
}

@keyframes blink {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.detail-section {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #4CAF50;
  padding-left: 20rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  border-top: 1rpx solid #eee;
  z-index: 100;
  gap: 20rpx;
}

.quantity-selector {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 10rpx;
  height: 70rpx;
  border: 1rpx solid #ddd;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  cursor: pointer;
  transition: background 0.2s;
}

.qty-btn:active {
  background: #e0e0e0;
  border-radius: 50%;
}

.qty-value {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.btn-consult, .btn-cart, .btn-buy {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  transition: all 0.2s;
}

.btn-cart {
  border: 2rpx solid #4CAF50;
  color: #4CAF50;
  width: 25%;
}

.btn-buy {
  color: white;
  width: 45%;
  box-shadow: 0 8rpx 16rpx rgba(76, 175, 80, 0.3);
}
