.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.profile-card { background: #fff; border-radius: 30rpx; padding: 40rpx; display: flex; flex-direction: column; align-items: center; }
.avatar-box { margin-bottom: 40rpx; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 80rpx; background: #eee; border: 4rpx solid #4CAF50; }
.info-list { width: 100%; margin-bottom: 50rpx; }
.info-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #eee; }
.label { width: 160rpx; font-size: 28rpx; color: #666; }
.input-val { flex: 1; font-size: 28rpx; color: #333; text-align: left; }
.readonly { color: #999; }
.update-btn { width: 100%; background: #4CAF50; color: #fff; border-radius: 45rpx; height: 90rpx; line-height: 90rpx; font-weight: bold; }
