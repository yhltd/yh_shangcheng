.category-container {
  height: 100vh;
  background-color: #f5f5f5;
}

.category-main {
  display: flex;
  height: 100%;
}

.category-left {
  width: 220rpx;
  background-color: #fff;
  border-right: 1px solid #eee;
  overflow-y: auto;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  border-left: 8rpx solid transparent;
}

.category-item.active {
  background-color: #f0f9f0;
  border-left: 8rpx solid #4CAF50;
}

.category-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #4CAF50;
  font-weight: bold;
}

.category-right {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

.sub-category-placeholder {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: #bbb;
  font-size: 28rpx;
}

.sub-category-content {
  animation: fadeIn 0.3s ease-in;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.section-title {
  text-align: center;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.sub-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: flex-start;
}

.sub-item {
  background: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #444;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  border: 1px solid #eee;
  transition: all 0.2s;
}

.sub-item.active {
  background-color: #e8f5e9;
  border-color: #4CAF50;
  color: #4CAF50;
  font-weight: bold;
}

.sub-item:active {
  background-color: #e8f5e9;
  border-color: #4CAF50;
}

.display-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.back-btn {
  font-size: 26rpx;
  color: #4CAF50;
  margin-right: 30rpx;
  cursor: pointer;
}

.display-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.product-scroll {
  flex: 1;
  height: calc(100% - 100rpx);
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.product-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.product-price {
  font-size: 28rpx;
  color: #e4393c;
  font-weight: bold;
}

.no-products {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  margin-top: 100rpx;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}
