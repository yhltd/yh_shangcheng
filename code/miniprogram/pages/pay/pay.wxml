<view class="container">
  <view class="header">
    <text class="title">V2 快捷支付测试</text>
    <text class="subtitle">用于验证支付通道可用性</text>
  </view>

  <view class="form-card">
    <view class="form-group">
      <text class="label">订单号</text>
      <input class="input" placeholder="请输入订单号 (如: TEST123)" value="{{orderId}}" bindinput="onInputOrderId" />
    </view>

    <view class="form-group">
      <text class="label">支付金额 (分)</text>
      <input class="input" type="number" placeholder="请输入金额，单位：分" value="{{amount}}" bindinput="onInputAmount" />
    </view>

    <button class="pay-btn" bindtap="submitOrder">立即发起支付</button>
  </view>

  <view class="tips">
    <text>提示：本页面直接调用 V2 支付云函数 'pay'</text>
    <text>请确保云函数已部署并配置了正确的 partnerKey</text>
  </view>
</view>
