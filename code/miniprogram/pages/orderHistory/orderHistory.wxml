<view class="container">
  <view class="order-empty" wx:if="{{orders.length === 0}}">
    <text>暂无订单记录</text>
    <button class="btn-home" bindtap="goHome">返回首页</button>
  </view>

  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orders}}" wx:key="ddh">
      <view class="order-header">
        <text class="order-id">订单号: {{item.ddh}}</text>
        <text class="order-date">{{item.xdrq}}</text>
      </view>
      <view class="order-body">
        <text class="product-name">{{item.cpmc}}</text>
        <view class="product-detail">
          <text>数量: {{item.xssl}}</text>
          <text style="margin-left: 20rpx;">单价: ￥{{item.xsdj}}</text>
        </view>
      </view>
      <view class="order-footer">
        <view>合计: <text class="total-amount">￥{{item.xshj}}</text></view>
        <text class="status-tag {{item.ddzt === '下单' ? 'status-ordered' : 'status-returned'}}">
          {{item.ddzt}}
        </text>
      </view>
    </view>
  </view>
</view>
