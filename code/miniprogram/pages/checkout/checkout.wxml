<view class="checkout-container">
  <!-- 收货地址 -->
  <view class="section-card address-section" bindtap="chooseAddress">
    <view class="section-header">
      <text class="title">收货地址</text>
      <text class="arrow">></text>
    </view>
    <view class="address-info">
      <view class="user-detail">
        <text class="user-name">{{address.name || '请添加收货地址'}}</text>
        <text class="user-phone">{{address.phone || ''}}</text>
      </view>
      <view class="address-text">{{address.detail || '点击设置配送地址'}}</view>
    </view>
  </view>

  <!-- 订单商品 -->
  <view class="section-card order-section">
    <view class="section-header">
      <text class="title">订单商品</text>
    </view>
    <view class="product-list">
      <view class="product-item" wx:for="{{items}}" wx:key="id">
        <image src="{{item.img}}" mode="aspectFill" class="product-img"></image>
        <view class="product-detail">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <text class="product-price">￥{{item.price}}</text>
            <text class="product-qty">x{{item.count || 1}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section-card payment-section">
    <view class="section-header">
      <text class="title">支付方式</text>
    </view>
    <view class="payment-options">
      <view class="payment-item {{payMethod === 'wechat' ? 'active' : ''}}" bindtap="selectPayMethod" data-method="wechat">
        <text class="pay-icon">微信支付</text>
        <radio checked="{{payMethod === 'wechat'}}" color="#4CAF50" />
      </view>
      <view class="payment-item {{payMethod === 'alipay' ? 'active' : ''}}" bindtap="selectPayMethod" data-method="alipay">
        <text class="pay-icon">支付宝支付</text>
        <radio checked="{{payMethod === 'alipay'}}" color="#4CAF50" />
      </view>
    </view>
  </view>

  <!-- 订单备注 -->
  <view class="section-card remark-section">
    <view class="remark-row">
      <text class="title">订单备注</text>
      <input class="remark-input" placeholder="请输入配送备注" bindinput="onRemarkInput" />
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="footer-bar">
    <view class="total-section">
      <text class="total-label">合计</text>
      <text class="total-amount">￥{{totalPrice}}</text>
    </view>
    <button class="submit-btn" bindtap="submitOrder">提交订单</button>
  </view>
</view>