<view class="store-container">
  <!-- 店铺头部 -->
  <view class="store-header">
    <view class="store-info">
      <image src="https://cdn-icons-png.flaticon.com/128/1063/1063376.png" class="store-logo"></image>
      <view class="store-text">
        <view class="store-name-row">
          <text class="store-name">{{dianpuName}}</text>
          <view class="qr-btn" bindtap="goToQrCode" catchtap="goToQrCode">二维码</view>
        </view>
        <text class="store-status">官方认证商家</text>
      </view>
    </view>
    <view class="store-stats">
      <view class="stat-item">
        <text class="stat-val">{{products.length}}</text>
        <text class="stat-label">商品</text>
      </view>
    </view>
  </view>

  <!-- 店铺 Banner -->
  <view class="store-banner">
    <image src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=800&q=80" mode="aspectFill"></image>
    <view class="banner-overlay">
      <text class="banner-title">欢迎光临我的店铺</text>
      <text class="banner-subtitle">精选优质产品，诚信经营，品质保证</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-section">
    <view class="section-title">店内商品</view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image src="{{item.img}}" mode="aspectFill" class="product-img"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <text class="product-price">￥{{item.price}}</text>
            <text class="product-stock">库存: {{item.shuliang}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{products.length === 0}}">
      <text>店铺内暂无商品，请前往管理后台上架</text>
    </view>
  </view>
</view>