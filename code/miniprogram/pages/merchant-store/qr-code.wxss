.store- {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.qr-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  text-align: center;
}

.qr-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.qr-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.qr-subtitle {
  font-size: 26rpx;
  color: #888;
}

.qr-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.qr-code-area {
  width: 400rpx;
  height: 400rpx;
  background: #fff;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 20rpx;
}

.qr-image {
  width: 100%;
  height: 100%;
}

.qr-url-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  word-break: break-all;
  max-width: 400rpx;
}

.action-area {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  width: 100%;
  margin-top: 60rpx;
}

.copy-btn, .save-btn {
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.copy-btn {
  background: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

.save-btn {
  background: linear-gradient(90deg, #4CAF50, #81C784);
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(76, 175, 80, 0.3);
}

.tips-box {
  margin-top: 60rpx;
  padding: 30rpx;
  background: #fffbe6;
  border-radius: 20rpx;
  border: 1rpx solid #ffe58f;
}

.tips-text {
  font-size: 24rpx;
  color: #856404;
  text-align: center;
  line-height: 1.6;
}
