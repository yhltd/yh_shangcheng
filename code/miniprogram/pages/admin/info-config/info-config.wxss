.admin-container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.page-header { margin-bottom: 30rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.config-list { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 40rpx; }
.config-item { padding: 30rpx; background: #fff; border-radius: 20rpx; display: flex; flex-direction: column; }
.label { font-size: 28rpx; color: #666; margin-bottom: 20rpx; }
.config-input { background: #f9f9f9; padding: 20rpx; border-radius: 10rpx; border: 1rpx solid #eee; font-size: 28rpx; }
.config-textarea { background: #f9f9f9; padding: 20rpx; border-radius: 10rpx; border: 1rpx solid #eee; font-size: 28rpx; height: 120rpx; }
.save-btn { background: #4CAF50; color: #fff; border-radius: 45rpx; height: 90rpx; line-height: 90rpx; font-weight: bold; box-shadow: 0 10rpx 20rpx rgba(76, 175, 80, 0.2); }
