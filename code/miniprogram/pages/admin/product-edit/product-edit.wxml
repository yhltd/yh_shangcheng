<view class="edit-container">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">商品名称</text>
      <input class="form-input" value="{{product.mingcheng}}" placeholder="请输入名称" bindinput="onInputChange" data-field="mingcheng" />
    </view>
    <view class="form-item">
      <text class="form-label">商品详情</text>
      <textarea class="form-input" value="{{product.xiangqing}}" placeholder="请输入详情" bindinput="onInputChange" data-field="xiangqing" />
    </view>
    <view class="form-item">
      <text class="form-label">分类</text>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}" range-key="name">
        <view class="form-input">
          {{categories[categoryIndex] ? categories[categoryIndex].name : '请选择分类'}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">子类</text>
      <picker bindchange="onSubCategoryChange" value="{{subCategoryIndex}}" range="{{subCategories}}">
        <view class="form-input">
          {{subCategories[subCategoryIndex] ? subCategories[subCategoryIndex] : '请选择子类'}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">原价</text>
      <input class="form-input" type="digit" value="{{product.yuanjia}}" placeholder="0.00" bindinput="onInputChange" data-field="yuanjia" />
    </view>
    <view class="form-item">
      <text class="form-label">折扣</text>
      <input class="form-input" type="digit" value="{{product.zhekou}}" placeholder="例如: 0.8" bindinput="onInputChange" data-field="zhekou" />
    </view>
    <view class="form-item">
      <text class="form-label">数量</text>
      <input class="form-input" type="number" value="{{product.shuliang}}" placeholder="0" bindinput="onInputChange" data-field="shuliang" />
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" value="{{product.beizhu}}" placeholder="请输入备注" bindinput="onInputChange" data-field="beizhu" />
    </view>
  </view>

  <view class="form-card">
    <text class="form-label">展示图</text>
    <view class="image-upload-section">
      <view class="image-box" bindtap="uploadImage" data-field="ztu">
        <image wx:if="{{product.ztu}}" src="{{product.ztu}}" mode="aspectFill" />
        <text wx:else class="image-placeholder">上传展示图</text>
      </view>
    </view>
  </view>

  <view class="form-card">
    <text class="form-label">轮播图</text>
    <view class="image-upload-section">
      <view class="image-box" bindtap="uploadImage" data-field="ltu1">
        <image wx:if="{{product.ltu1}}" src="{{product.ltu1}}" mode="aspectFill" />
        <text wx:else class="image-placeholder">图1</text>
      </view>
      <view class="image-box" bindtap="uploadImage" data-field="ltu2">
        <image wx:if="{{product.ltu2}}" src="{{product.ltu2}}" mode="aspectFill" />
        <text wx:else class="image-placeholder">图2</text>
      </view>
      <view class="image-box" bindtap="uploadImage" data-field="ltu3">
        <image wx:if="{{product.ltu3}}" src="{{product.ltu3}}" mode="aspectFill" />
        <text wx:else class="image-placeholder">图3</text>
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="handleSubmit">更新商品</button>
</view>
