<view class="admin-container">
  <view class="page-header">
    <text class="title">盈利统计</text>
  </view>

  <view class="stats-grid">
    <view class="stat-card primary">
      <text class="stat-label">总营业额</text>
      <text class="stat-value">￥{{totalRevenue}}</text>
      <text class="stat-trend">实时同步中</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">订单总量</text>
      <text class="stat-value">{{totalOrders}}</text>
      <text class="stat-trend">已完成订单</text>
    </view>
  </view>

  <view class="chart-placeholder card">
    <text class="chart-title">热门产品统计 (Top 5)</text>
    <view class="custom-chart-container">
      <view class="chart-row" wx:for="{{hotProducts}}" wx:key="pname">
        <view class="chart-info">
          <text class="product-name">{{item.pname}}</text>
          <text class="product-count">{{item.count}} 单</text>
        </view>
        <view class="bar-bg">
          <view class="bar-fill" style="{{item.barStyle}}"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="recent-orders">
    <text class="sub-title">近期订单</text>
    <view class="order-item card" wx:for="{{recentOrders}}" wx:key="id">
      <text class="order-id">订单号: {{item.id}}</text>
      <text class="order-amount">￥{{item.amount}}</text>
    </view>
  </view>
</view>