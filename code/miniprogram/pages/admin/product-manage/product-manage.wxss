.admin-container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.page-header { margin-bottom: 30rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.action-bar { margin-bottom: 30rpx; display: flex; justify-content: flex-end; }
.add-btn { background: #4CAF50; color: #fff; font-size: 26rpx; padding: 0 30rpx; height: 70rpx; line-height: 70rpx; border-radius: 35rpx; }
.product-list { display: flex; flex-direction: column; gap: 20rpx; }
.product-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; background: #fff; border-radius: 15rpx; }
.prod-info { display: flex; flex-direction: column; }
.prod-name { font-size: 30rpx; font-weight: bold; color: #333; }
.prod-detail { font-size: 24rpx; color: #888; margin-top: 10rpx; }
.prod-actions { display: flex; gap: 20rpx; }
.edit-text { color: #4CAF50; font-size: 26rpx; }
.del-text { color: #E4393C; font-size: 26rpx; }
