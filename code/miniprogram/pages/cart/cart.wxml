<view class="container">
  <view class="cart-empty" wx:if="{{cartItems.length === 0}}">
    <text>购物车空空如也</text>
    <button class="btn-primary" bindtap="goHome">去购物</button>
  </view>

  <view class="cart-list" wx:else>
    <view class="select-all-header">
      <view class="checkbox-wrapper" bindtap="toggleSelectAll" data-value="{{!selectAll}}">
        <checkbox checked="{{selectAll}}" color="#4CAF50" />
      </view>
      <text>全选</text>
    </view>
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
      <view class="cart-item-main">
        <view class="checkbox-wrapper" bindtap="toggleSelect" data-index="{{index}}" data-value="{{!item.selected}}">
          <checkbox checked="{{item.selected}}" color="#4CAF50" />
        </view>
        <view class="item-info">
          <text class="name">{{item.name}}</text>
          <text class="price">￥{{item.price}}</text>
        </view>
        <view class="item-qty">
          <text>数量: {{item.count}}</text>
        </view>
      </view>
      <view class="cart-item-actions">
        <button class="btn-delete-subtle" bindtap="deleteItem" data-id="{{item.id}}">删除</button>
      </view>
    </view>
    <view class="footer-bar">
      <text>合计: <text class="total-price">￥{{totalPrice}}</text></text>
      <button class="btn-buy btn-primary" bindtap="checkout">结算</button>
    </view>
  </view>
</view>
