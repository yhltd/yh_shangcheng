.apply-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.header-section {
  position: relative;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  z-index: 1;
  border-bottom-left-radius: 80rpx;
  border-bottom-right-radius: 80rpx;
}

.header-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  color: #fff;
}

.header-img {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
  filter: brightness(0) invert(1);
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.content-wrapper {
  flex: 1;
  padding: 0 30rpx;
  margin-top: -40rpx;
  z-index: 3;
}

.notice-card, .benefit-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.card-title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.dot-wrapper {
  width: 16rpx;
  height: 16rpx;
  background-color: #4CAF50;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.notice-item .text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.benefit-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.benefit-item {
  background: #f9fbf9;
  border: 1rpx solid #eef2ee;
  padding: 24rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.2s;
}

.benefit-item:active {
  background-color: #e8f5e9;
  transform: scale(0.98);
}

.b-icon {
  font-size: 40rpx;
}

.b-text {
  font-size: 26rpx;
  color: #444;
  font-weight: 500;
}

.bottom-action {
  padding: 40rpx 30rpx 60rpx;
}

.apply-btn {
  background: linear-gradient(90deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 60rpx;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
  box-shadow: 0 12rpx 24rpx rgba(76, 175, 80, 0.3);
  transition: all 0.2s;
}

.apply-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
